{
  "name": "@rue-js/runtime",
  "version": "0.0.33",
  "description": "@rue-js/runtime",
  "keywords": [
    "rue"
  ],
  "homepage": "https://github.com/hunzhiwange/ruejs/tree/main/packages/runtime#readme",
  "bugs": {
    "url": "https://github.com/hunzhiwange/ruejs/issues"
  },
  "license": "MIT",
  "author": "Xiangmin Liu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hunzhiwange/ruejs.git",
    "directory": "src/packages/runtime"
  },
  "files": [
    "index.js",
    "dist",
    "src/vapor.ts"
  ],
  "sideEffects": false,
  "main": "index.js",
  "module": "dist/runtime.esm-bundler.js",
  "types": "dist/runtime.d.ts",
  "unpkg": "dist/runtime.global.js",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "development": "./src/index.ts",
      "node": {
        "production": "./dist/runtime.cjs.prod.js",
        "development": "./dist/runtime.cjs.js",
        "default": "./index.js"
      },
      "module": "./dist/runtime.esm-bundler.js",
      "import": "./dist/runtime.esm-bundler.js",
      "require": "./index.js"
    },
    "./vapor": {
      "types": "./src/vapor.ts",
      "development": "./src/vapor.ts",
      "node": {
        "production": "./dist/runtime.vapor.cjs.prod.js",
        "development": "./dist/runtime.vapor.cjs.js",
        "default": "./dist/runtime.vapor.cjs.js"
      },
      "module": "./dist/runtime.vapor.esm-bundler.js",
      "import": "./dist/runtime.vapor.esm-bundler.js",
      "require": "./dist/runtime.vapor.cjs.js"
    },
    "./*": "./*"
  },
  "dependencies": {
    "@rue-js/rue": "workspace:*",
    "@rue-js/runtime-vapor": "workspace:*",
    "@rue-js/shared": "workspace:*",
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@types/trusted-types": "^2.0.7"
  },
  "buildOptions": {
    "name": "RueRuntimeDOM",
    "formats": [
      "esm-bundler",
      "esm-browser",
      "cjs",
      "global"
    ],
    "subEntries": [
      {
        "entry": "src/vapor.ts",
        "filename": "runtime.vapor",
        "formats": [
          "esm-bundler",
          "cjs"
        ]
      }
    ]
  }
}
