{
  "name": "@rue-js/rue",
  "version": "0.0.33",
  "description": "后悔药 Rue.js - The Wasm Framework For Vapor Native DOM.",
  "keywords": [
    "rue"
  ],
  "homepage": "https://github.com/hunzhiwange/ruejs/tree/main/packages/rue#readme",
  "bugs": {
    "url": "https://github.com/hunzhiwange/ruejs/issues"
  },
  "license": "MIT",
  "author": "Xiangmin Liu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hunzhiwange/ruejs.git"
  },
  "files": [
    "index.js",
    "index.mjs",
    "dist",
    "src/vapor.ts",
    "jsx-runtime",
    "jsx-dev-runtime",
    "jsx.d.ts"
  ],
  "main": "index.js",
  "module": "dist/rue.runtime.esm-bundler.js",
  "types": "dist/rue.d.ts",
  "unpkg": "dist/rue.global.js",
  "jsdelivr": "dist/rue.global.js",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/rue.d.ts",
      "import": {
        "node": "./index.mjs",
        "default": "./dist/rue.runtime.esm-bundler.js"
      },
      "require": {
        "node": {
          "production": "./dist/rue.cjs.prod.js",
          "development": "./dist/rue.cjs.js",
          "default": "./index.js"
        },
        "default": "./index.js"
      }
    },
    "./vapor": {
      "types": "./src/vapor.ts",
      "development": "./src/vapor.ts",
      "node": {
        "production": "./dist/rue.vapor.cjs.prod.js",
        "development": "./dist/rue.vapor.cjs.js",
        "default": "./dist/rue.vapor.cjs.js"
      },
      "module": "./dist/rue.vapor.esm-bundler.js",
      "import": "./dist/rue.vapor.esm-bundler.js",
      "require": "./dist/rue.vapor.cjs.js"
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime/index.d.ts",
      "import": "./jsx-runtime/index.mjs",
      "require": "./jsx-runtime/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-runtime/index.d.ts",
      "import": "./jsx-runtime/index.mjs",
      "require": "./jsx-runtime/index.js"
    },
    "./jsx": "./jsx.d.ts",
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@rue-js/runtime": "workspace:*",
    "@rue-js/shared": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "*"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "buildOptions": {
    "name": "rue",
    "formats": [
      "esm-bundler",
      "esm-bundler-runtime",
      "cjs",
      "global",
      "global-runtime",
      "esm-browser",
      "esm-browser-runtime"
    ],
    "subEntries": [
      {
        "entry": "src/vapor.ts",
        "filename": "rue.vapor",
        "formats": [
          "esm-bundler",
          "cjs"
        ]
      }
    ]
  }
}
