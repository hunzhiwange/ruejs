{
  "name": "@rue-js/swc-plugin-rue",
  "version": "0.0.31",
  "description": "通过 SWC 实现 JSX 中转化为原生DOM",
  "keywords": [
    "@rue-js/swc-plugin-rue",
    "jsx",
    "swc",
    "swc-plugin"
  ],
  "homepage": "https://github.com/hunzhiwange/ruejs/tree/main/packages/swc-plugin-rue#readme",
  "bugs": {
    "url": "https://github.com/hunzhiwange/ruejs/issues"
  },
  "license": "MIT",
  "author": "Xiangmin Liu",
  "repository": {
    "type": "git",
    "url": "https://github.com/hunzhiwange/ruejs",
    "directory": "packages/swc-plugin-rue"
  },
  "files": [
    "swc-plugin-rue.wasm",
    "README.md",
    "LICENSE"
  ],
  "main": "swc-plugin-rue.wasm",
  "exports": {
    ".": "./swc-plugin-rue.wasm"
  },
  "scripts": {
    "build": "cargo fmt --all && cargo build --release --target wasm32-wasip1",
    "postbuild": "node -e \"const fs=require('fs');fs.copyFileSync('target/wasm32-wasip1/release/swc_plugin_rue.wasm','swc-plugin-rue.wasm')\"",
    "test": "cargo test",
    "format": "cargo fmt --all",
    "docs": "cargo doc --no-deps",
    "prepublishOnly": "npm run build",
    "check": "cargo check",
    "fmt": "cargo fmt",
    "test-coverage": "cargo llvm-cov  --html --open"
  }
}
