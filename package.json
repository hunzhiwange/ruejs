{
  "name": "rue-site",
  "version": "0.0.31",
  "private": true,
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "directories": {
    "example": "examples"
  },
  "type": "module",
  "main": "rollup.config.js",
  "scripts": {
    "app-dev": "vite",
    "app-build": "vite build",
    "dev": "node scripts/dev.js",
    "build": "node scripts/build.js",
    "build-dts": "tsc -p tsconfig.build.json --noCheck && rollup -c rollup.dts.config.js",
    "test-dts": "pnpm run build-dts",
    "clean": "rimraf --glob packages/*/dist temp .eslintcache",
    "size": "run-s \"size-*\" && node scripts/usage-size.js",
    "size-global": "node scripts/build.js rue runtime -f global -p --size",
    "size-esm-runtime": "node scripts/build.js rue -f esm-bundler-runtime",
    "size-esm": "node scripts/build.js runtime shared -f esm-bundler",
    "check": "tsc --incremental --noEmit",
    "lint": "oxlint -c ./.oxlintrc.json .",
    "lint-fix": "oxlint -c ./.oxlintrc.json . --fix",
    "oxlint": "oxlint -c ./.oxlintrc.json .",
    "oxlint-fix": "oxlint -c ./.oxlintrc.json . --fix",
    "prettier-format": "oxfmt .",
    "prettier-format-check": "oxfmt --check .",
    "format": "oxfmt .",
    "format-check": "oxfmt --check .",
    "test": "vitest run",
    "test-watch": "vitest",
    "test-unit": "vitest run --project unit*",
    "test-unit-watch": "vitest --project unit*",
    "test-coverage": "vitest run --coverage",
    "test-e2e": "node scripts/build.js rue -f global -d && vitest run --project e2e --passWithNoTests",
    "test-coverage-unit": "vitest run --project unit* --coverage",
    "prebench": "node scripts/build.js -pf esm-browser",
    "prebench-compare": "node scripts/build.js -pf esm-browser",
    "bench": "vitest bench --project=unit --outputJson=temp/bench.json",
    "bench-compare": "vitest bench --project=unit --compare=temp/bench.json",
    "release": "node scripts/release.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "dev-esm": "node scripts/dev.js -if esm-bundler-runtime",
    "dev-sfc": "run-s dev-sfc-prepare",
    "dev-sfc-prepare": "node scripts/pre-dev-sfc.js || npm run build-all-cjs",
    "serve": "serve",
    "build-sfc-playground": "run-s build-all-cjs build-runtime-esm build-browser-esm build-sfc-playground-self",
    "build-all-cjs": "node scripts/build.js rue runtime shared -af cjs",
    "build-runtime-esm": "node scripts/build.js runtime shared -af esm-bundler && node scripts/build.js rue -f esm-bundler-runtime && node scripts/build.js rue -f esm-browser-runtime",
    "build-browser-esm": "node scripts/build.js runtime shared -af esm-bundler && node scripts/build.js rue -f esm-bundler && node scripts/build.js rue -f esm-browser",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "@rue-js/app-rust": "workspace:*",
    "@rue-js/design": "workspace:*",
    "@rue-js/jsx-runtime": "workspace:*",
    "@rue-js/learn-wgpu": "workspace:*",
    "@rue-js/plugin": "workspace:*",
    "@rue-js/router": "workspace:*",
    "@rue-js/rue": "workspace:*",
    "@rue-js/runtime": "workspace:*",
    "@rue-js/runtime-vapor": "workspace:*",
    "@rue-js/shared": "workspace:*",
    "@rue-js/vite-plugin-rue": "workspace:*",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "shiki": "^3.19.0"
  },
  "devDependencies": {
    "@babel/parser": "catalog:",
    "@babel/types": "catalog:",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "5.0.4",
    "@rue-js/jsx-dev-runtime": "workspace:*",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "@types/animejs": "^3.1.13",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/eslint-plugin": "^1.4.0",
    "c8": "^10.1.3",
    "conventional-changelog-cli": "^5.0.0",
    "daisyui": "^5.5.11",
    "enquirer": "^2.4.1",
    "esbuild": "^0.25.12",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "eslint": "^9.27.0",
    "eslint-plugin-import-x": "^4.13.1",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.0.0",
    "magic-string": "^0.30.21",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.5.3",
    "pretty-bytes": "^7.1.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.52.5",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "semver": "^7.7.3",
    "serve": "^14.2.5",
    "serve-handler": "^6.1.6",
    "simple-git-hooks": "^2.13.0",
    "swc-plugin-jsx-css-modules": "^0.3.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.1",
    "vite": "8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^2.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm check",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "*.{js,json}": [
      "oxfmt ."
    ],
    "*.ts?(x)": [
      "oxlint . --fix",
      "oxfmt ."
    ]
  },
  "packageManager": "pnpm@10.20.0",
  "lint-staged-bak": {
    "*.{js,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  }
}
